Remove VS Code branding from welcome screen content

This patch removes Microsoft VS Code branding from the welcome screen and replaces it with
generic development environment content.

Index: code-server/lib/vscode/src/vs/workbench/contrib/welcomeGettingStarted/common/gettingStartedContent.ts
===================================================================
--- code-server.orig/lib/vscode/src/vs/workbench/contrib/welcomeGettingStarted/common/gettingStartedContent.ts
+++ code-server/lib/vscode/src/vs/workbench/contrib/welcomeGettingStarted/common/gettingStartedContent.ts
@@ -356,8 +356,8 @@ export const content: GettingStartedWal
 
 	{
 		id: 'SetupWeb',
-		title: localize('gettingStarted.setupWeb.title', "Get Started with VS Code for the Web"),
-		description: localize('gettingStarted.setupWeb.description', "Customize your editor, learn the basics, and start coding"),
+		title: localize('gettingStarted.setupWeb.title', "Get Started with Your Development Environment"),
+		description: localize('gettingStarted.setupWeb.description', "Customize your editor, learn the basics, and start coding"),
 		isFeatured: true,
 		icon: setupIcon,
 		when: 'isWeb',
@@ -702,8 +702,8 @@ export const content: GettingStartedWal
 	},
 	{
 		id: `${NEW_WELCOME_EXPERIENCE}`,
-		title: localize('gettingStarted.new.title', "Get started with VS Code"),
-		description: localize('gettingStarted.new.description', "Supercharge coding with AI"),
+		title: localize('gettingStarted.new.title', "Get started with your development environment"),
+		description: localize('gettingStarted.new.description', "Customize your coding environment"),
 		isFeatured: false,
 		icon: setupIcon,
 		when: '!isWeb',
@@ -760,8 +760,8 @@ export const content: GettingStartedWal
 
